{
  "version": "0.2.0-c25-c2-guard-v2",
  "description": "Structural guard against hardcoded user-question routing in Agent Runtime.",
  "runtime_scopes": [
    "core-platform/services/agent_runtime_service/app/planner.py",
    "core-platform/services/agent_runtime_service/app/planning",
    "core-platform/services/agent_runtime_service/app/executor.py",
    "core-platform/services/agent_runtime_service/app/renderer.py",
    "core-platform/services/agent_runtime_service/app/runtime"
  ],
  "allowed_files": [
    "core-platform/data/agent_policy/planner_policy.json",
    "core-platform/data/agent_policy/entity_aliases.json",
    "core-platform/data/agent_policy/hardcode_guard.json",
    "core-platform/services/agent_runtime_service/app/policy/loader.py",
    "core-platform/services/agent_runtime_service/app/planning/legacy_rule_planner.py",
    "core-platform/data/agent_policy/capability_registry.json",
    "core-platform/data/agent_policy/capability_status.json",
    "core-platform/services/agent_runtime_service/app/execution/tool_dispatch_registry.py",
    "core-platform/services/agent_runtime_service/app/config/runtime_config.py",
    "core-platform/services/agent_runtime_service/app/tools.py",
    "core-platform/services/agent_runtime_service/app/mcp/registry.py",
    "core-platform/services/agent_runtime_service/app/health/planner_health.py",
    "core-platform/services/agent_runtime_service/app/planning/llm_planner.py",
    "core-platform/services/model_gateway/main.py",
    "core-platform/data/runtime_config/runtime_config.json",
    "core-platform/scripts/build/generate_desktop_runtime_config.py",
    "core-platform/docs/reports"
  ],
  "blocked_literals": [
    "元神",
    "原神",
    "米哈游",
    "广州",
    "深圳",
    "北京",
    "上海",
    "东京",
    "Guangzhou",
    "Shenzhen",
    "Beijing",
    "Shanghai",
    "Tokyo",
    "明天",
    "后天",
    "昨天",
    "前天",
    "今天几号",
    "今天是几号",
    "三天后",
    "两天后",
    "chinese_number",
    "CN_LOCATION_MAP",
    "WEATHER_CODE"
  ],
  "query_variable_names": [
    "query",
    "message",
    "text",
    "normalized",
    "normalized_query",
    "user_text",
    "user_input",
    "prompt"
  ],
  "routing_assignment_name_fragments": [
    "alias",
    "aliases",
    "keyword",
    "keywords",
    "intent_rule",
    "intent_rules",
    "typo",
    "typo_map"
  ],
  "allowed_literal_prefixes": [
    "http://",
    "https://",
    "/agent/",
    "/api/",
    "core-platform/",
    "application/",
    "Content-Type",
    "User-Agent"
  ],
  "allowed_literal_exact": [
    "",
    "ok",
    "error",
    "message",
    "result",
    "items",
    "tools",
    "capabilities",
    "metadata",
    "runtime",
    "provider",
    "enabled",
    "disabled",
    "low",
    "medium",
    "high",
    "unknown",
    "GET",
    "POST",
    "LOCAL",
    "DISABLED",
    "model.generate",
    "repo_memory.search",
    "web.search",
    "weather.query",
    "browser.fetch",
    "filesystem.write",
    "filesystem.read",
    "filesystem.list",
    "shell.exec",
    "capability.match",
    "capability.status",
    "time.now",
    "time.date_math"
  ],
  "notes": [
    "Runtime code may contain protocol/tool/schema constants.",
    "Runtime code must not contain question-specific literals used for routing.",
    "Concrete phrases/entities/questions belong in external policy, memory, provider responses, or LLM planner output."
  ]
}
