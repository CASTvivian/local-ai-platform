{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Platform",
  "version": "0.1.0",
  "identifier": "com.castvivian.localaiplatform",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:19000",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Local AI Platform",
        "width": 1440,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../../../scripts/windows/ensure_runtime.ps1",
      "../../../scripts/windows/bootstrap_runtime.ps1",
      "../../../scripts/windows/start_all.ps1",
      "../../../scripts/windows/stop_all.ps1",
      "../../../scripts/windows/status_all.ps1",
      "../../../services/model_bootstrap_service",
      "../../../services/model_gateway",
      "../../../services/agent_runtime_service",
      "../../../services/repo_memory_service",
      "../../../services/skill_store_service",
      "../../../services/workflow_store_service",
      "../../../services/artifact_registry_service",
      "../../../services/code_review_gate_service",
      "../../../services/design_system_service",
      "../../../services/document_ingestion_service",
      "../../../services/agent_orchestrator",
      "../../../data/agent_policy",
      "../../../data/runtime_config",
      "../../../data/planner_runtime",
      "../../../data/sandbox_policy",
      "../../../data/agent_team",
      "../../../data/brain_assets/manifests",
      "../../../data/brain_assets/model_catalog",
      "../../../data/brain_assets/reports",
      "../../../data/brain_assets/video_catalog",
      "../../../data/github_stars",
      "../../../data/skill_brain",
      "../../../scripts/mac"
    ]
  }
}
